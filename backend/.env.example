# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hrms?schema=public"

# JWT (shared expiry config; Platform and Tenant use their own secrets)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Platform JWT
PLATFORM_JWT_ACCESS_SECRET=platform-access-secret
PLATFORM_JWT_REFRESH_SECRET=platform-refresh-secret

# Tenant JWT (separate from Platform)
TENANT_JWT_ACCESS_SECRET=tenant-access-secret-min-32-chars-change-in-production
TENANT_JWT_REFRESH_SECRET=tenant-refresh-secret-min-32-chars-change-in-production

# SMTP / Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SECURE=false

# File Storage
FILE_STORAGE_PROVIDER=postgres

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
PLATFORM_DOMAIN=localhost:3000

# Default Super Admin (used by seed script)
DEFAULT_SUPER_ADMIN_EMAIL=admin@hrms-platform.com
DEFAULT_SUPER_ADMIN_PASSWORD=change-me
DEFAULT_SUPER_ADMIN_NAME=Platform Admin
